generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AccountType {
  REVENUE
  GATEWAY_RECEIVABLE
}

model Order {
  id           String        @id @default(uuid()) @db.Uuid
  wix_order_id String        @unique
  product_id   Int
  amount       Decimal       @db.Decimal(19, 2)
  status       OrderStatus   @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ledger       LedgerEntry[]

  @@map("orders")
}

model LedgerEntry {
  id             String      @id @default(uuid()) @db.Uuid
  transaction_id String      @db.Uuid
  account_type   AccountType
  amount         Decimal     @db.Decimal(19, 2)
  createdAt      DateTime    @default(now())

  order Order @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  @@index([transaction_id])
  @@map("ledger_entries")
}
